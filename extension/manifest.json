{
  "manifest_version": 3,
  "name": "Foldex Capture",
  "version": "1.4.5",
  "description": "Save the current tab to your Foldex bookmark manager.",
  "permissions": ["activeTab", "storage", "notifications"],
  "host_permissions": ["http://localhost:9089/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Foldex"
  },
  "options_page": "options.html"
}
