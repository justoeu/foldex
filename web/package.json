{
  "name": "foldex-web",
  "private": true,
  "version": "1.5.5",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "coverage:nogate": "vitest run --coverage --coverage.thresholds.lines=0 --coverage.thresholds.statements=0 --coverage.thresholds.functions=0 --coverage.thresholds.branches=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "9.0.1",
    "@tanstack/react-query": "^5.100.5",
    "axios": "^1.16.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hotkeys-hook": "^5.2.4",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9",
    "@testing-library/react": "^16.3",
    "@testing-library/user-event": "^14.6",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "@vitejs/plugin-react": "^6.0",
    "@vitest/coverage-v8": "^4.1",
    "jsdom": "^29",
    "typescript": "^6.0",
    "vite": "^8.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1"
  }
}
