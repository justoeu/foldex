# Foldex environment configuration
# Copy to .env and edit as needed. All values are sane defaults for local dev.

# ---- Image tag pulled from Docker Hub ----
# `make up` uses justoeu/foldex-{backend,web}:${FOLDEX_VERSION}. Common values:
#   latest         → newest build from main
#   sha-<7chars>   → pin to a specific commit
#   v1.2.3         → pin to a release tag (when one exists)
# Leave unset to default to `latest`. Use `make up-build` to ignore this and
# build from local source instead.
FOLDEX_VERSION=latest

# ---- Postgres (single source of truth) ----
POSTGRES_USER=foldex
POSTGRES_PASSWORD=foldex
POSTGRES_DB=foldex
POSTGRES_PORT=5432
# Hostname seen by the backend container:
#  - `db`                    → self-hosted via docker-compose.db.yml (default)
#  - `localhost` / `host.docker.internal` → reuse a Postgres on your host
#  - any reachable hostname  → external DB (RDS, etc.)
POSTGRES_HOST=db

# Postgres SSL mode used by the backend driver. Valid values (see PG docs):
#   disable | allow | prefer | require | verify-ca | verify-full
# Default is `disable` for local dev. Use `require` (or stricter) for any
# Postgres reachable over the public internet.
POSTGRES_SSLMODE=disable

# DB_URL is DERIVED from the POSTGRES_* vars above (see docker-compose.yml
# and backend/Makefile). Override DB_URL only if you need a fully custom DSN
# that the variables above can't express.
#DB_URL=postgres://user:pass@host:5432/dbname?sslmode=disable

# ---- Backend ----
BACKEND_PORT=9089

# Inside-container listen address. Default empty → backend's own default of
# 127.0.0.1 applies (correct for bare-host deploys per CLAUDE.md §0).
# Docker Compose overrides this to 0.0.0.0 automatically so nginx in the
# sibling container can reach the backend; the host-side port mapping
# remains loopback-only via BIND_HOST.
BACKEND_BIND=

# Worker concurrency for URL preview fetcher (keep <= pgxpool max / 2).
PREVIEW_WORKER_CONCURRENCY=4
PREVIEW_FETCH_TIMEOUT_SEC=5

# When set to `1`/`true`, the preview worker refuses to dial private IP
# ranges (loopback, RFC1918, link-local, IPv6 ULA). Default is permissive
# because foldex is a single-user local app and intranet links (Jira, Grid,
# Confluence, internal dashboards) are first-class targets. IMDS
# (169.254.169.254) is always blocked regardless of this flag.
PREVIEW_STRICT_SSRF=

# Optional shared-secret guard for /api endpoints (leave empty to disable).
# When set, callers must send `X-Foldex-Secret: <value>` on /api requests.
SHARED_SECRET=

# CORS origins allowed by the backend (comma-separated). Defaults to the
# bundled HTTPS web origin. Do NOT use `*` here with the Compose deployment:
# Compose binds the backend to 0.0.0.0 (so nginx can reach it) and with an
# empty SHARED_SECRET that wildcard trips the secure-defaults guard, which
# refuses to boot (config.validateSecureDefaults). Set a concrete origin, or
# a SHARED_SECRET, before loosening this.
CORS_ORIGINS=https://localhost

# ---- MinIO (object storage for screenshots) ----
# Endpoint seen by the backend container:
#  - `minio:9000` → self-hosted via docker-compose.services.yml (default)
#  - `localhost:9000` → MinIO running directly on the host
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=foldex-screenshots
MINIO_USE_SSL=false

# ---- Change-detection worker (per-link opt-in) ----
# When CHANGECHECK_ENABLED=1 the backend runs a background worker that
# re-fetches each opted-in link (link.check_interval = hourly/daily/weekly)
# and emits a Web Push notification when the page's content fingerprint
# changes. Set to 0 (or empty) to disable the worker entirely.
CHANGECHECK_ENABLED=1
CHANGECHECK_WORKER_CONCURRENCY=2
CHANGECHECK_SCAN_INTERVAL_SEC=60
CHANGECHECK_FETCH_TIMEOUT_SEC=20

# ---- Web Push / VAPID ----
# Identity keys used by the Web Push protocol (RFC 8030). Leave empty +
# VAPID_AUTO_GENERATE=1 to let the backend generate and persist a keypair
# under VAPID_STATE_PATH on first boot. Pin both keys in .env for stable
# behaviour across container recreations — otherwise every fresh container
# invalidates all browser subscriptions (the public key changes).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:foldex@localhost
VAPID_AUTO_GENERATE=1
VAPID_STATE_PATH=/data/vapid.json

# ---- Web ----
WEB_PORT=9088
WEB_HTTPS_PORT=9444
# Base URL of the backend, as seen from the user's browser.
VITE_API_BASE=http://localhost:9089

# ---- LAN access (phones / iPads on the same wifi) ----
# Default 127.0.0.1 = loopback only — the safe default for the single-user,
# no-public-exposure threat model. Set WEB_BIND_HOST=0.0.0.0 to reach the
# SPA at https://<your-mac-LAN-ip>:9444 from another device on the wifi.
# Re-emit the mkcert pair with the same LAN IP in its SAN list, otherwise
# the phone's browser rejects the cert before nginx even sees the request.
# Backend stays loopback-only by default — nginx proxies /api/ + /go/, so
# the backend doesn't need a second open port on the LAN.
WEB_BIND_HOST=127.0.0.1
BIND_HOST=127.0.0.1
